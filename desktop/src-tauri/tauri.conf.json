{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Approximate Query Engine",
  "version": "0.1.0",
  "identifier": "com.womentechies26.aqe",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Approximate Query Engine",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["../../backend/bin/aqe-backend"]
  }
}
